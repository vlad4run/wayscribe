# Host GID owning /dev/accel/accel0 (the "render" group on most Linux distros).
# Find yours with:   getent group render | cut -d: -f3
RENDER_GID=485

# Multimodal LLM that runs alongside Whisper. Whisper itself is always
# enabled via `--asr 1` in the compose command. Pick something small if
# you only want voice-to-text and a tiny chat model:
#   gemma3:1b   ~0.7 GB    (default)
#   qwen3:0.6b  ~0.4 GB    (fastest decode)
#   llama3.2:1b ~1.2 GB
FLM_LLM_MODEL=gemma3:1b

# HTTP port published on the host. flm-voice's default endpoint is 52625.
FLM_PORT=52625
